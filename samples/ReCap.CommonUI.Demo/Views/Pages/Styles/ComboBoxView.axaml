<UserControl x:Class="ReCap.CommonUI.Demo.Views.Pages.Styles.ComboBoxView"
            xmlns="https://github.com/avaloniaui"
			xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<UserControl.Styles>
		<Style Selector="ComboBox.sample-items">
			<Setter Property="ItemsSource" Value="{Binding SampleItems, Mode=OneWay}" />
		</Style>
		<Style Selector="ComboBox.sample-items > ComboBoxItem">
			<Setter Property="IsEnabled" Value="{Binding $self.DataContext.Enabled, Mode=OneWay}" />
		</Style>

		<Style Selector="UniformGrid > HeaderedContentControl">
			<Setter Property="Content" Value="{Binding $parent[UserControl].DataContext, Mode=OneWay}" />
			<Setter Property="ContentTemplate">
				<DataTemplate>
					<StackPanel Orientation="Vertical"
								Spacing="8">
						<ComboBox SelectedIndex="0"
								Classes="sample-items"
								HorizontalAlignment="Stretch" />

						<ComboBox PlaceholderText="Placeholder text"
								Classes="sample-items" />

						<ComboBox />

						<ComboBox SelectedIndex="0"
								Classes="sample-items"
								HorizontalAlignment="Stretch">
							<DataValidationErrors.Error>
								<x:Exception />
							</DataValidationErrors.Error>
						</ComboBox>
					</StackPanel>
				</DataTemplate>
			</Setter>
		</Style>
	</UserControl.Styles>
	<UniformGrid Rows="1"
				ColumnSpacing="20">
		<HeaderedContentControl Header="Enabled" />
		<HeaderedContentControl Header="Disabled"
								IsEnabled="False" />
	</UniformGrid>
</UserControl>